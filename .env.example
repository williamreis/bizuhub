# BizuHub - copie para .env e preencha. NUNCA commitar .env.
# SECRET_KEY: gere uma chave longa (ex: openssl rand -hex 32)
SECRET_KEY=substitua-por-uma-chave

# CORS: origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000
API_URL=http://localhost:8000

# Banco PostgreSQL (no Docker: postgresql://bizuhub:bizuhub@db:5432/bizuhub)
DATABASE_URL=postgresql://bizuhub:bizuhub@localhost:5432/bizuhub

# APIs externas (obtenha em tmdb.org e Google Cloud)
TMDB_API_KEY=
GOOGLE_BOOKS_API_KEY=

# Groq (console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Telegram bot (opcional; BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Rate limit (requisições por minuto por IP)
RATE_LIMIT_PER_MINUTE=60
